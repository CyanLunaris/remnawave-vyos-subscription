# /etc/remnaproxy/config.env
SUBSCRIPTION_URL=https://panel.example.com/sub/YOUR_TOKEN_HERE
SYNC_INTERVAL=10min
HEARTBEAT_INTERVAL=30s
HEARTBEAT_HOST=cp.cloudflare.com
HEARTBEAT_FAIL_THRESHOLD=2
HEARTBEAT_TIMEOUT=5

GEO_DIRECT_IP=private,ru
GEO_DIRECT_SITE=category-ru
TUN_INTERFACE=tun0
TUN_ADDRESS=172.19.0.1/30

# TUN network stack. "mixed" uses gvisor for UDP/ICMP and the kernel stack for TCP.
# This is optimal for router use with multiple devices (IoT, game consoles, phones).
# Values: mixed (default) | system | gvisor
# TUN_STACK=mixed

# Enable Generic Segmentation Offload. Batches small packets before passing them to
# sing-box, significantly reducing CPU overhead under high concurrency.
# Requires Linux kernel 4.x+ (standard on any modern VyOS).
# TUN_GSO=false

# Optional: multiplex protocol for TCP-based outbounds (reduces TLS handshake overhead).
# Multiplexes multiple streams over a single VPN connection — subsequent requests use
# the existing TLS session instead of performing a new handshake.
# Values: smux | yamux | h2mux  (leave empty to disable)
# Requires server-side support; not needed for gRPC/xHTTP (they multiplex natively).
# MULTIPLEX_PROTOCOL=h2mux

# Number of VPN connections in the multiplex pool. More connections = more parallelism
# across devices, at the cost of more TLS sessions on the server.
# Recommended: ~2× the number of LAN devices that are actively online simultaneously.
# MULTIPLEX_MAX_CONNECTIONS=4

# Paths — defaults work out of the box; change only if you need a custom layout.
# XRAY_BIN is downloaded automatically by the sync process if the file is missing
# (e.g. on a fresh install or after a container image update).
XRAY_BIN=/usr/local/bin/sing-box
XRAY_CONFIG=/etc/sing-box/config.json
NODES_FILE=/etc/remnaproxy/nodes.json
STATE_FILE=/etc/remnaproxy/state.json
LOG_DIR=/var/log/remnaproxy
RULE_SET_DIR=/etc/sing-box
